// Development tsconfig, do not use for build
{
  "compilerOptions": {
    "outDir": "./build",
    "rootDir": ".",
    "allowJs": true,
    "target": "ES2017",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "module": "commonjs",
    "paths": {
      "*": ["./src/*"]
    },
    "emitDecoratorMetadata": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "strict": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*", "e2e/**/*"],
  "exclude": ["./client", "./build"]
}
