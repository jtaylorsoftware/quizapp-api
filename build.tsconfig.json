{
  "compilerOptions": {
    "outDir": "./build",
    "rootDir": "./src",
    "allowJs": true,
    "target": "ES2017",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "module": "commonjs",
    "emitDecoratorMetadata": true,
    "paths": {
      "*": ["./src/*"]
    },
    "strict": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build", "e2e", "src/**/*.test.ts"]
}
